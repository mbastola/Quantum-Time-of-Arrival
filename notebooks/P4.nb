Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"psi", "[", 
       RowBox[{"i_", ",", "x_", ",", "t_"}], "]"}], ":=", 
      RowBox[{
       RowBox[{"psi", "[", 
        RowBox[{"0", ",", "x", ",", "t"}], "]"}], "-", 
       RowBox[{"psi", "[", 
        RowBox[{"0", ",", "xp", ",", 
         RowBox[{"tm", "[", "i", "]"}]}], "]"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Psi]", "[", 
     RowBox[{"0", ",", "x_", ",", "t_"}], "]"}], ":=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       FractionBox[
        SuperscriptBox["\[Delta]", "2"], 
        RowBox[{"2", "\[Pi]"}]], ")"}], 
      RowBox[{"1", "/", "4"}]], "*", 
     FractionBox[
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         SubsuperscriptBox["k", "0", "2"]}], "*", 
        SuperscriptBox["\[Delta]", "2"]}], "]"}], 
      SqrtBox[
       RowBox[{
        SuperscriptBox["\[Delta]", "2"], "+", 
        FractionBox[
         RowBox[{"\[ImaginaryI]", "*", "t"}], "2"]}]]], "*", 
     RowBox[{"Exp", "[", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", "*", 
           SuperscriptBox["\[Delta]", "2"], "*", " ", 
           SubscriptBox["k", "0"]}], " ", "+", " ", 
          RowBox[{"\[ImaginaryI]", "*", 
           RowBox[{"(", 
            RowBox[{"x", "-", 
             SubscriptBox["X", "0"]}], ")"}]}]}], ")"}], "2"], 
       RowBox[{
        RowBox[{"4", "*", 
         SuperscriptBox["\[Delta]", "2"]}], " ", "+", " ", 
        RowBox[{"2", "*", "\[ImaginaryI]", "*", "t"}]}]], "]"}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"K", "[", 
     RowBox[{"xf_", ",", "tf_", ",", "xi_", ",", "ti_"}], "]"}], ":=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox[
       RowBox[{"2", "*", "\[Pi]", "*", "\[ImaginaryI]", "*", 
        RowBox[{"(", 
         RowBox[{"tf", "-", "ti"}], ")"}]}]]], "*", 
     RowBox[{"Exp", "[", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", "*", 
        SuperscriptBox[
