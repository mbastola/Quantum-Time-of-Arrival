Cell[CellGroupData[{

Cell[TextData[StyleBox["Random Position Approximations", "Subtitle"]], "Title",
 CellChangeTimes->{{3.6076929735615654`*^9, 3.607692980851982*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"m", "=", "10"}], ";", 
  RowBox[{"list2", "=", 
   RowBox[{"{", "}"}]}], ";", 
  RowBox[{
   SubscriptBox["X", "0"], "=", 
   RowBox[{"-", "5"}]}], ";", 
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"acc", "[", "i", "]"}], "=", "0"}], ";", 
           RowBox[{
            RowBox[{"bcc", "[", "i", "]"}], "=", "0"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"tm", "[", "i", "]"}], "=", 
               RowBox[{
                RowBox[{"tm", "[", 
                 RowBox[{"i", "-", "1"}], "]"}], "+", "dt"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"a", "[", "1", "]"}], ":=", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"\[Psi]", "[", 
                 RowBox[{"0", ",", 
                  RowBox[{"RandomReal", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    SubscriptBox["X", "d"], "-", 
                    RowBox[{"D1", "/", "2"}]}], ",", 
                    RowBox[{
                    SubscriptBox["X", "d"], "+", 
                    RowBox[{"D1", "/", "2"}]}]}], "}"}], "]"}], ",", 
                  RowBox[{"tm", "[", "1", "]"}]}], "]"}], "]"}], "*", 
               RowBox[{"Sqrt", "[", "D1", "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b", "[", "1", "]"}], "=", 
              SqrtBox[
               RowBox[{"1", "-", 
                SuperscriptBox[
                 RowBox[{"(", 
                  RowBox[{"a", "[", "1", "]"}], ")"}], "2"]}]]}], ";", 
             RowBox[{
              RowBox[{"acc", "[", "1", "]"}], "+=", 
              RowBox[{"a", "[", "1", "]"}]}], ";", 
             RowBox[{
              RowBox[{"bcc", "[", "1", "]"}], "+=", 
              RowBox[{"b", "[", "1", "]"}]}], ";", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"\[Alpha]", "[", 
                 RowBox[{"0", ",", "j"}], "]"}], ":=", 
                RowBox[{"\[Psi]", "[", 
                 RowBox[{"0", ",", 
                  RowBox[{"RandomReal", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    SubscriptBox["X", "d"], "-", 
                    RowBox[{"D1", "/", "2"}]}], ",", 
                    RowBox[{
                    SubscriptBox["X", "d"], "+", 
                    RowBox[{"D1", "/", "2"}]}]}], "}"}], "]"}], ",", 
                  RowBox[{"tm", "[", "j", "]"}]}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", "1", ",", 
                 RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{"Do", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"\[Beta]", "[", 
                   RowBox[{"i", ",", "j"}], "]"}], ":=", 
                  RowBox[{"K", "[", 
                   RowBox[{
                    RowBox[{"RandomReal", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    SubscriptBox["X", "d"], "-", 
                    RowBox[{"D1", "/", "2"}]}], ",", 
                    RowBox[{
                    SubscriptBox["X", "d"], "+", 
                    RowBox[{"D1", "/", "2"}]}]}], "}"}], "]"}], ",", "0", ",", 
                    RowBox[{"RandomReal", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{
                    SubscriptBox["X", "d"], "-", 
                    RowBox[{"D1", "/", "2"}]}], ",", 
                    RowBox[{
                    SubscriptBox["X", "d"], "+", 
                    RowBox[{"D1", "/", "2"}]}]}], "}"}], "]"}], ",", 
                    RowBox[{
                    RowBox[{"tm", "[", "j", "]"}], "-", 
                    RowBox[{"tm", "[", "i", "]"}]}]}], "]"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", 
                   RowBox[{"i", "+", "1"}], ",", 
                   RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";", 
             RowBox[{"Do", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Do", "[", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"\[Alpha]", "[", 
                    RowBox[{"i", ",", "j"}], "]"}], "=", 
                   RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"\[Alpha]", "[", 
                    RowBox[{
                    RowBox[{"i", "-", "1"}], ",", "j"}], "]"}], "-", 
                    RowBox[{
                    RowBox[{"\[Alpha]", "[", 
                    RowBox[{
                    RowBox[{"i", "-", "1"}], ",", "i"}], "]"}], "*", 
                    RowBox[{"\[Beta]", "[", 
                    RowBox[{"i", ",", "j"}], "]"}], "*", "D1"}]}], ")"}], "/", 
                    RowBox[{"b", "[", "i", "]"}]}]}], ",", 
                  RowBox[{"{", 
                   RowBox[{"j", ",", 
                    RowBox[{"i", "+", "1"}], ",", 
                    RowBox[{"n", "+", "1"}]}], "}"}]}], "]"}], ";", 
                RowBox[{
                 RowBox[{"a", "[", 
                  RowBox[{"i", "+", "1"}], "]"}], "=", 
                 RowBox[{
                  RowBox[{"Abs", "[", 
                   RowBox[{"\[Alpha]", "[", 
                    RowBox[{"i", ",", 
                    RowBox[{"i", "+", "1"}]}], "]"}], "]"}], "*", 
                  RowBox[{"Sqrt", "[", "D1", "]"}]}]}], ";", 
                RowBox[{
                 RowBox[{"b", "[", 
                  RowBox[{"i", "+", "1"}], "]"}], "=", 
                 SqrtBox[
                  RowBox[{"1", "-", 
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{"a", "[", 
